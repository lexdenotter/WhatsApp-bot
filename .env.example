# Kopieer dit bestand naar .env (naast docker-compose.yml) en pas aan waar nodig.
# Let op: de Telegram-bot-token en Gemini-API-key horen NIET in dit bestand —
# die voer je in n8n zelf in als credentials (zie README).

GENERIC_TIMEZONE=Europe/Amsterdam
TZ=Europe/Amsterdam

# Het (sub)domein waarop je bot bereikbaar is, bijv. via DuckDNS.
# Moet naar het publieke IP van je server wijzen voordat je "docker compose up -d" draait,
# anders kan Caddy geen HTTPS-certificaat aanvragen.
N8N_HOST=huishoudbot.duckdns.org
