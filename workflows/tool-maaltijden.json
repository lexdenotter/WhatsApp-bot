              "outputKey": "historie"
            },
            {
              "conditions": {
                "options": {"caseSensitive": false, "leftValue": "", "typeValidation": "loose", "version": 2},
                "combinator": "and",
                "conditions": [
                  {"id": "r3", "leftValue": "={{ $json.actie }}", "rightValue": "voorkeur_opslaan", "operator": {"type": "string", "operation": "equals"}}
                ]
              },
              "renameOutput": true,
              "outputKey": "voorkeur_opslaan"
            },
            {
              "conditions": {
                "options": {"caseSensitive": false, "leftValue": "", "typeValidation": "loose", "version": 2},
