      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-300, -240],
      "parameters": {
        "jsCode": "const invoer = $('Normaliseren').first().json;\nif (!invoer.gerecht) {\n  return [{ json: { resultaat: 'Er is geen gerecht opgegeven om te loggen.' } }];\n}\nreturn [{ json: { resultaat: `Genoteerd: op ${invoer.datum} eten jullie ${invoer.gerecht}.` } }];"
      }
    },
