    {
      "id": "c1000000-0000-4000-8000-000000000001",
      "name": "Aangeroepen als tool",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [-1200, 0],
      "parameters": {
        "workflowInputs": {
          "values": [
            {"name": "actie"},
            {"name": "gerecht"},
            {"name": "datum"},
            {"name": "sleutel"},
            {"name": "waarde"}
          ]
        }
      }
    },
    {
      "id": "c1000000-0000-4000-8000-000000000002",
      "name": "Normaliseren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-980, 0],
      "parameters": {
        "jsCode": "const j = $input.first().json;\nconst actie = String(j.actie || '').toLowerCase().trim();\nconst gerecht = String(j.gerecht || '').trim();\nlet datum = String(j.datum || '').trim();\nif (!/^\\d{4}-\\d{2}-\\d{2}$/.test(datum)) {\n  datum = new Date().toISOString().slice(0, 10);\n}\nconst sleutel = String(j.sleutel || '').toLowerCase().trim();\nconst waarde = String(j.waarde || '').trim();\nreturn [{ json: { actie, gerecht, datum, sleutel, waarde } }];"
      }
    },
    {
      "id": "c1000000-0000-4000-8000-000000000003",
      "name": "Welke actie?",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [-760, 0],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {"caseSensitive": false, "leftValue": "", "typeValidation": "loose", "version": 2},
                "combinator": "and",
                "conditions": [
                  {"id": "r1", "leftValue": "={{ $json.actie }}", "rightValue": "loggen", "operator": {"type": "string", "operation": "equals"}}
                ]
              },
              "renameOutput": true,
              "outputKey": "loggen"
            },
            {
              "conditions": {
                "options": {"caseSensitive": false, "leftValue": "", "typeValidation": "loose", "version": 2},
                "combinator": "and",
                "conditions": [
                  {"id": "r2", "leftValue": "={{ $json.actie }}", "rightValue": "historie", "operator": {"type": "string", "operation": "equals"}}
