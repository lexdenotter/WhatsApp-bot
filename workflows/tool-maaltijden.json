      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-300, 120],
      "parameters": {
        "jsCode": "const invoer = $('Normaliseren').first().json;\nif (!invoer.sleutel || !invoer.waarde) {\n  return [{ json: { resultaat: 'Om een voorkeur op te slaan zijn zowel een sleutel als een waarde nodig.' } }];\n}\nreturn [{ json: { resultaat: `Voorkeur opgeslagen: ${invoer.sleutel} = ${invoer.waarde}` } }];"
      }
