    {
      "id": "c1000000-0000-4000-8000-000000000007",
      "name": "Toon historie",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-300, -60],
      "parameters": {
        "jsCode": "const rijen = $input.all().map(i => i.json).filter(r => r && r.gerecht);\nif (!rijen.length) {\n  return [{ json: { resultaat: 'Er zijn nog geen maaltijden gelogd.' } }];\n}\nrijen.sort((a, b) => String(b.gegeten_op).localeCompare(String(a.gegeten_op)));\nconst recent = rijen.slice(0, 20);\nconst regels = recent.map(r => `• ${r.gegeten_op}: ${r.gerecht}`);\nreturn [{ json: { resultaat: `Laatst gegeten maaltijden (nieuwste eerst):\\n${regels.join('\\n')}` } }];"
      }
    },
