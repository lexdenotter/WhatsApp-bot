    {
      "id": "c1000000-0000-4000-8000-00000000000b",
      "name": "Toon voorkeuren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-300, 300],
      "parameters": {
        "jsCode": "const rijen = $input.all().map(i => i.json).filter(r => r && r.sleutel);\nif (!rijen.length) {\n  return [{ json: { resultaat: 'Er zijn nog geen eetvoorkeuren opgeslagen.' } }];\n}\nconst regels = rijen.map(r => `• ${r.sleutel}: ${r.waarde}`);\nreturn [{ json: { resultaat: `Opgeslagen voorkeuren:\\n${regels.join('\\n')}` } }];"
      }
