      "parameters": {
        "jsCode": "const invoer = $('Normaliseren').first().json;\nif (!invoer.items.length) {\n  return [{ json: { resultaat: 'Er zijn geen items opgegeven om toe te voegen.' } }];\n}\nreturn [{ json: { resultaat: `Toegevoegd aan de lijst '${invoer.lijst}': ${invoer.items.join(', ')}` } }];"
