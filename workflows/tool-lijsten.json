      "position": [-520, -300],
      "parameters": {
        "jsCode": "const j = $input.first().json;\nif (!j.items.length) {\n  return [{ json: { resultaat: 'Er zijn geen items opgegeven om toe te voegen.' } }];\n}\nreturn j.items.map(tekst => ({ json: { lijst: j.lijst, tekst, afzender: j.afzender } }));"
      }
