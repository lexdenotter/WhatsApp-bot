    {
      "id": "b1000000-0000-4000-8000-00000000000c",
      "name": "Zoek items (afvinken)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-300, 240],
      "parameters": {
        "jsCode": "const invoer = $('Normaliseren').first().json;\nconst rijen = $input.all().map(i => i.json).filter(r => r && r.tekst && String(r.klaar) !== 'ja');\nconst gezocht = invoer.items.map(s => s.toLowerCase());\nconst matches = rijen.filter(r => {\n  const t = String(r.tekst).toLowerCase();\n  return gezocht.some(z => t.includes(z) || z.includes(t));\n});\nif (!gezocht.length) {\n  return [{ json: { id: '', geenMatch: true, melding: 'Geen items opgegeven om af te vinken.' } }];\n}\nif (!matches.length) {\n  return [{ json: { id: '', geenMatch: true, melding: `Niets gevonden op de lijst '${invoer.lijst}' dat lijkt op: ${invoer.items.join(', ')}` } }];\n}\nreturn matches.map(r => ({ json: { id: r.id, tekst: r.tekst } }));"
      }
