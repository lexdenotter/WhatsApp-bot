    {
      "id": "b1000000-0000-4000-8000-000000000002",
      "name": "Normaliseren",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-980, 0],
      "parameters": {
        "jsCode": "const j = $input.first().json;\nconst actie = String(j.actie || '').toLowerCase().trim();\nconst lijst = (String(j.lijst || '').toLowerCase().trim()) || 'boodschappen';\nconst items = String(j.items || '')\n  .split(',')\n  .map(s => s.trim())\n  .filter(Boolean);\nconst afzender = String(j.afzender || 'onbekend');\nreturn [{ json: { actie, lijst, items, afzender } }];"
      }
    },
