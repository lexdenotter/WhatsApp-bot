    {
      "id": "b1000000-0000-4000-8000-000000000008",
      "name": "Toon lijst",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-300, -120],
      "parameters": {
        "jsCode": "const invoer = $('Normaliseren').first().json;\nconst rijen = $input.all().map(i => i.json).filter(r => r && r.tekst);\nconst open = rijen.filter(r => String(r.klaar) !== 'ja');\nif (!open.length) {\n  return [{ json: { resultaat: `De lijst '${invoer.lijst}' is leeg.` } }];\n}\nconst regels = open.map(r => `• ${r.tekst}`);\nreturn [{ json: { resultaat: `Op de lijst '${invoer.lijst}' staat:\\n${regels.join('\\n')}` } }];"
      }
    },
    {
      "id": "b1000000-0000-4000-8000-000000000009",
      "name": "Haal alle items op",
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1,
