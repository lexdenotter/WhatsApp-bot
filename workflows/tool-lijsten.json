    {
      "id": "b1000000-0000-4000-8000-00000000000a",
      "name": "Toon overzicht",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-300, 60],
      "parameters": {
        "jsCode": "const rijen = $input.all().map(i => i.json).filter(r => r && r.tekst);\nconst open = rijen.filter(r => String(r.klaar) !== 'ja');\nif (!open.length) {\n  return [{ json: { resultaat: 'Alle lijsten zijn leeg.' } }];\n}\nconst perLijst = {};\nfor (const r of open) {\n  const l = r.lijst || 'boodschappen';\n  (perLijst[l] = perLijst[l] || []).push(r.tekst);\n}\nconst blokken = Object.entries(perLijst).map(([l, ts]) => `${l}:\\n` + ts.map(t => `• ${t}`).join('\\n'));\nreturn [{ json: { resultaat: blokken.join('\\n\\n') } }];"
      }
    },
