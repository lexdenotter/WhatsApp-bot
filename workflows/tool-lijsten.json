      "position": [140, 240],
      "parameters": {
        "jsCode": "const gevonden = $('Zoek items (afvinken)').all().map(i => i.json);\nif (gevonden.length && gevonden[0].geenMatch) {\n  return [{ json: { resultaat: gevonden[0].melding } }];\n}\nconst namen = gevonden.map(g => g.tekst);\nreturn [{ json: { resultaat: `Afgevinkt: ${namen.join(', ')}` } }];"
